<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#07375E"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            app:title="Pet Details"
            app:titleTextColor="@android:color/white"
            app:navigationIconTint="@android:color/white"
            app:navigationIcon="@drawable/ic_arrow_back" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hero Section with Enhanced Design -->
            <RelativeLayout
                android:id="@+id/heroSection"
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:background="#07375E">

                <!-- Decorative circles for visual interest -->
                <View
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    android:layout_alignParentEnd="true"
                    android:layout_marginTop="-50dp"
                    android:layout_marginEnd="-50dp"
                    android:background="@drawable/circle_accent"
                    android:alpha="0.1" />

                <View
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_alignParentStart="true"
                    android:layout_alignParentBottom="true"
                    android:layout_marginStart="-30dp"
                    android:layout_marginBottom="-30dp"
                    android:background="@drawable/circle_accent"
                    android:alpha="0.15" />

                <!-- Pet Image with Enhanced Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPetImage"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="50dp"
                    app:cardCornerRadius="70dp"
                    app:cardElevation="12dp"
                    app:strokeWidth="4dp"
                    app:strokeColor="@android:color/white">

                    <ImageView
                        android:id="@+id/imageViewPetDetail"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_pet_default"
                        android:background="@android:color/white" />

                </com.google.android.material.card.MaterialCardView>

                <!-- Pet Name with Animation -->
                <TextView
                    android:id="@+id/textViewPetName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/cardPetImage"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="16dp"
                    android:text="Milo"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:alpha="0"
                    android:translationY="20dp" />

                <!-- Pet Quick Info Pills -->
                <LinearLayout
                    android:id="@+id/quickInfoLayout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/textViewPetName"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:alpha="0"
                    android:translationY="20dp">

                    <TextView
                        android:id="@+id/quickBreed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/pill_background"
                        android:text="Labrador"
                        android:textColor="@android:color/white"
                        android:textSize="12sp"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/quickAge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/pill_background"
                        android:text="2 years"
                        android:textColor="@android:color/white"
                        android:textSize="12sp"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp" />

                </LinearLayout>

            </RelativeLayout>

            <!-- Main Content with Enhanced Cards -->
            <LinearLayout
                android:id="@+id/mainContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="-30dp"
                android:background="@drawable/white_rounded_top_background"
                android:padding="24dp"
                android:alpha="0"
                android:translationY="30dp">

                <!-- Pet Information Header with Enhanced Design -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp"
                    android:gravity="center_vertical"
                    android:background="@drawable/info_header_background"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_dialog_info"
                        android:layout_marginEnd="12dp"
                        app:tint="#07375E" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Pet's Information"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#07375E" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonEdit"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Edit"
                        android:textSize="12sp"
                        android:minWidth="0dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        style="@style/Widget.Material3.Button.TextButton"
                        app:backgroundTint="#07375E"
                        android:textColor="@android:color/white"
                        app:cornerRadius="18dp" />

                </LinearLayout>

                <!-- Enhanced Pet Details with Icons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="24dp"
                    android:background="@drawable/details_card_background"
                    android:padding="20dp">

                    <!-- Breed Row -->
                    <LinearLayout
                        android:id="@+id/breedRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp"
                        android:gravity="center_vertical"
                        android:background="@drawable/detail_row_ripple"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_info_details"
                            android:layout_marginEnd="12dp"
                            app:tint="#07375E" />

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="Breed"
                            android:textSize="16sp"
                            android:textColor="#07375E"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/textViewPetBreed"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Labrador Retriever"
                            android:textSize="16sp"
                            android:textColor="@android:color/black"
                            android:gravity="end" />

                    </LinearLayout>

                    <!-- Gender Row -->
                    <LinearLayout
                        android:id="@+id/genderRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp"
                        android:gravity="center_vertical"
                        android:background="@drawable/detail_row_ripple"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_preferences"
                            android:layout_marginEnd="12dp"
                            app:tint="#07375E" />

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="Sex"
                            android:textSize="16sp"
                            android:textColor="#07375E"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/textViewGender"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Male"
                            android:textSize="16sp"
                            android:textColor="@android:color/black"
                            android:gravity="end" />

                    </LinearLayout>

                    <!-- Date of Birth Row -->
                    <LinearLayout
                        android:id="@+id/dobRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/detail_row_ripple"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_today"
                            android:layout_marginEnd="12dp"
                            app:tint="#07375E" />

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="Date of birth"
                            android:textSize="16sp"
                            android:textColor="#07375E"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/textViewDateOfBirth"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="31.03.22 (2 years)"
                            android:textSize="16sp"
                            android:textColor="@android:color/black"
                            android:gravity="end" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Enhanced Medicine Section -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/medicineCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="8dp"
                    app:strokeWidth="2dp"
                    app:strokeColor="#07375E"
                    android:alpha="0"
                    android:translationY="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/card_gradient_background">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="20dp"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@android:drawable/ic_dialog_alert"
                                android:layout_marginEnd="12dp"
                                app:tint="#07375E" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Medicines"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="#07375E" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/buttonAddMedicine"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=" Add"
                                style="@style/Widget.Material3.Button.TextButton"
                                app:backgroundTint="#07375E"
                                android:textColor="@android:color/white"
                                app:cornerRadius="20dp"
                                android:textSize="14sp"
                                app:icon="@android:drawable/ic_input_add"
                                app:iconTint="@android:color/white" />

                        </LinearLayout>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recyclerViewMedicines"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            android:paddingHorizontal="20dp"
                            android:paddingBottom="20dp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Enhanced Vaccination Section -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/vaccinationCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="8dp"
                    app:strokeWidth="2dp"
                    app:strokeColor="#07375E"
                    android:alpha="0"
                    android:translationY="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/card_gradient_background">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="20dp"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@android:drawable/ic_dialog_alert"
                                android:layout_marginEnd="12dp"
                                app:tint="#07375E" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Vaccinations"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="#07375E" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/buttonAddVaccination"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=" Add"
                                style="@style/Widget.Material3.Button.TextButton"
                                app:backgroundTint="#07375E"
                                android:textColor="@android:color/white"
                                app:cornerRadius="20dp"
                                android:textSize="14sp"
                                app:icon="@android:drawable/ic_input_add"
                                app:iconTint="@android:color/white" />

                        </LinearLayout>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recyclerViewVaccinations"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            android:paddingHorizontal="20dp"
                            android:paddingBottom="20dp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Enhanced Appointments Section -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/appointmentCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="8dp"
                    app:strokeWidth="2dp"
                    app:strokeColor="#07375E"
                    android:alpha="0"
                    android:translationY="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/card_gradient_background">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="20dp"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@android:drawable/ic_menu_today"
                                android:layout_marginEnd="12dp"
                                app:tint="#07375E" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Appointments"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="#07375E" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/buttonAddAppointment"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=" Add"
                                style="@style/Widget.Material3.Button.TextButton"
                                app:backgroundTint="#07375E"
                                android:textColor="@android:color/white"
                                app:cornerRadius="20dp"
                                android:textSize="14sp"
                                app:icon="@android:drawable/ic_input_add"
                                app:iconTint="@android:color/white" />

                        </LinearLayout>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recyclerViewAppointments"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            android:paddingHorizontal="20dp"
                            android:paddingBottom="20dp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>