<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@android:color/white"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:strokeWidth="1dp"
    app:strokeColor="#E8F4FD">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header Section with Medicine Name and Frequency Badge -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/medicine_header_gradient"
            android:padding="16dp">

            <!-- Medicine Icon -->
            <ImageView
                android:id="@+id/imageViewMedicineIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_medication"
                android:background="@drawable/circular_button_background"
                android:padding="8dp"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/imageViewMedicineIcon"
                android:layout_centerVertical="true"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textViewMedicineName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Medicine Name"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:maxLines="2"
                    android:ellipsize="end" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/textViewFrequency"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Daily"
                    android:textSize="11sp"
                    android:textColor="@color/black"
                    app:chipBackgroundColor="#80FFFFFF"
                    app:chipStrokeColor="@android:color/white"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="12dp"
                    app:chipMinHeight="24dp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

        </RelativeLayout>

        <!-- Content Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@android:color/white">

            <!-- Dosage Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp"
                android:background="@drawable/dosage_background"
                android:padding="12dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_dosage"
                    android:layout_marginEnd="8dp"
                    app:tint="#4A90E2" />

                <TextView
                    android:id="@+id/textViewDosage"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Dosage :"
                    android:textSize="14sp"
                    android:textColor="#2C3E50"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Time Section with Individual Time Boxes -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/time_background"
                android:padding="12dp"
                android:layout_marginBottom="8dp">

                <!-- Time Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_access_time"
                        android:layout_marginEnd="8dp"
                        app:tint="#27AE60" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Schedule Times"
                        android:textSize="20sp"
                        android:textColor="#2C3E50"
                        android:textStyle="bold" />



                </LinearLayout>

                <!-- Time Boxes Container -->
                <LinearLayout
                    android:id="@+id/timeBoxesContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="start">

                    <!-- First Time Box -->
                    <LinearLayout
                        android:id="@+id/timeBox1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/time_box_background"
                        android:padding="12dp"
                        android:layout_marginEnd="8dp"
                        android:gravity="center"
                        android:minWidth="64dp">

                        <TextView
                            android:id="@+id/textViewTime1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="09:00"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#2C3E50"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AM"
                            android:textSize="10sp"
                            android:textColor="#7F8C8D"
                            android:layout_marginTop="2dp"
                            android:gravity="center" />

                    </LinearLayout>

                    <!-- Second Time Box -->
                    <LinearLayout
                        android:id="@+id/timeBox2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/time_box_background"
                        android:padding="12dp"
                        android:layout_marginEnd="8dp"
                        android:gravity="center"
                        android:minWidth="64dp">

                        <TextView
                            android:id="@+id/textViewTime2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="21:00"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#2C3E50"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PM"
                            android:textSize="10sp"
                            android:textColor="#7F8C8D"
                            android:layout_marginTop="2dp"
                            android:gravity="center" />

                    </LinearLayout>

                    <!-- Third Time Box (Optional - can be hidden if not needed) -->
                    <LinearLayout
                        android:id="@+id/timeBox3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/time_box_background"
                        android:padding="12dp"
                        android:layout_marginEnd="8dp"
                        android:gravity="center"
                        android:minWidth="64dp"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/textViewTime3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="13:00"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#2C3E50"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PM"
                            android:textSize="10sp"
                            android:textColor="#7F8C8D"
                            android:layout_marginTop="2dp"
                            android:gravity="center" />

                    </LinearLayout>

                    <!-- Fourth Time Box (Optional - can be hidden if not needed) -->
                    <LinearLayout
                        android:id="@+id/timeBox4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/time_box_background"
                        android:padding="12dp"
                        android:gravity="center"
                        android:minWidth="64dp"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/textViewTime4"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="17:00"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#2C3E50"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PM"
                            android:textSize="10sp"
                            android:textColor="#7F8C8D"
                            android:layout_marginTop="2dp"
                            android:gravity="center" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Hidden TextView for backward compatibility -->
                <TextView
                    android:id="@+id/textViewTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="09:00, 21:00"
                    android:textSize="14sp"
                    android:textColor="#2C3E50"
                    android:textStyle="bold"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>

        <!-- Status Bar -->
        <View
            android:id="@+id/viewStatusBar"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:background="#27AE60" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>