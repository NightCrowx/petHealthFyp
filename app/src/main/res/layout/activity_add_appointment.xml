<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background"
    android:padding="24dp"
    android:fillViewport="true"
    tools:context=".petschedule.ui.AddAppointmentActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_background"
        android:padding="32dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        android:elevation="8dp"
        android:translationZ="8dp">

        <!-- App Header Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅"
                android:textSize="50sp"
                android:layout_marginBottom="8dp"
                android:scaleX="1.2"
                android:scaleY="1.2"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="New Appointment"
                android:textStyle="bold"
                android:textSize="30sp"
                android:textColor="@color/primary_blue"
                android:gravity="center"
                android:letterSpacing="0.05"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Schedule your pet's next visit"
                android:textSize="18sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginTop="8dp"
                android:alpha="0.8"/>
        </LinearLayout>

        <!-- Appointment Title Field -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/appointment_title_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="@style/CustomTextInputLayout"
            app:boxStrokeColor="@color/primary_blue"
            app:hintTextColor="@color/primary_blue"
            app:startIconTint="@color/primary_blue"
            app:endIconMode="clear_text"
            app:endIconTint="@color/primary_blue"
            app:errorEnabled="true"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editTextAppointmentTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Appointment Title"
                android:inputType="text|textCapSentences"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:padding="16dp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Description Field -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/appointment_description_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="@style/CustomTextInputLayout"
            app:boxStrokeColor="@color/primary_blue"
            app:hintTextColor="@color/primary_blue"
            app:startIconTint="@color/primary_blue"
            app:endIconMode="clear_text"
            app:endIconTint="@color/primary_blue"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editTextAppointmentDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Description (Optional)"
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="2"
                android:maxLines="4"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:padding="16dp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Date & Time Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/appointment_date_layout"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                style="@style/CustomTextInputLayout"
                app:boxStrokeColor="@color/primary_blue"
                app:hintTextColor="@color/primary_blue"
                app:startIconTint="@color/primary_blue"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                android:layout_marginEnd="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editTextAppointmentDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Date"
                    android:inputType="none"
                    android:focusable="false"
                    android:clickable="true"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:padding="16dp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/appointment_time_layout"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                style="@style/CustomTextInputLayout"
                app:boxStrokeColor="@color/primary_blue"
                app:hintTextColor="@color/primary_blue"
                app:startIconTint="@color/primary_blue"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                android:layout_marginStart="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editTextAppointmentTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Time"
                    android:inputType="none"
                    android:focusable="false"
                    android:clickable="true"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:padding="16dp"/>
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Location Field -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/location_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            style="@style/CustomTextInputLayout"
            app:boxStrokeColor="@color/primary_blue"
            app:hintTextColor="@color/primary_blue"
            app:startIconTint="@color/primary_blue"
            app:endIconMode="clear_text"
            app:endIconTint="@color/primary_blue"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editTextLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Location (Optional)"
                android:inputType="text|textCapWords"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:padding="16dp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Enhanced Reminder Section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/primary_blue_light"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="@color/quantum_white_100">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reminder Time"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_blue"/>
                </LinearLayout>

                <RadioGroup
                    android:id="@+id/radioGroupReminderTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/radio15Minutes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="15 minutes before"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:padding="8dp"
                        android:layout_marginBottom="4dp"/>

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/radio30Minutes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="30 minutes before"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:padding="8dp"
                        android:layout_marginBottom="4dp"/>

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/radio1Hour"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1 hour before"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:padding="8dp"
                        android:layout_marginBottom="4dp"
                        android:checked="true"/>

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/radio1Day"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1 day before"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:padding="8dp"/>
                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Enhanced Save Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSaveAppointment"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Save Appointment"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@android:color/white"
            android:background="@drawable/gradient_button"
            app:cornerRadius="28dp"
            android:layout_marginBottom="16dp"
            android:elevation="4dp"
            app:rippleColor="@color/white_transparent"
            android:stateListAnimator="@animator/button_elevation"
            app:iconTint="@android:color/white"
            app:iconGravity="textStart"/>

        <!-- Progress Bar (Hidden by default) -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            app:indicatorColor="@color/primary_blue"
            app:trackColor="@color/primary_blue_light"
            app:trackCornerRadius="4dp" />

    </LinearLayout>
</ScrollView>