<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background">

    <!-- Scrollable Content -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottomNav"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingBottom="20dp"
            android:animateLayoutChanges="true">

            <!-- Header with Logo -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                android:backgroundTint="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="20dp">

                    <!-- Logo placeholder - you can replace with your actual logo -->
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/pawlifelogo"
                        android:layout_marginEnd="16dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PawLife"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="#2E5BBA" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pet Health Analyser"
                            android:textSize="14sp"
                            android:textColor="#6B7280" />

                    </LinearLayout>

                    <!-- Tips Button -->
                    <ImageButton
                        android:id="@+id/tipsButton"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_help"
                        android:background="@drawable/circular_button_background"
                        android:backgroundTint="#E8F2FF"
                        app:tint="#2E5BBA" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Instructions Card with Animation -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/instructionsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                android:backgroundTint="#E8F2FF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_camera"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="How it works"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#2E5BBA" />

                    </LinearLayout>

                    <!-- Step indicators -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <!-- Step 1 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">

                            <View
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:background="@drawable/step_circle"
                                android:layout_marginEnd="16dp" />

                            <TextView
                                android:layout_width="8dp"
                                android:layout_height="wrap_content"
                                android:text="1"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold"
                                android:textSize="12sp"
                                android:gravity="center"
                                android:layout_marginEnd="24dp"
                                android:layout_marginStart="-32dp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Upload a clear photo of your pet"
                                android:textSize="14sp"
                                android:textColor="#1F2937" />

                        </LinearLayout>

                        <!-- Step 2 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">

                            <View
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:background="@drawable/step_circle"
                                android:layout_marginEnd="16dp" />

                            <TextView
                                android:layout_width="8dp"
                                android:layout_height="wrap_content"
                                android:text="2"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold"
                                android:textSize="12sp"
                                android:gravity="center"
                                android:layout_marginEnd="24dp"
                                android:layout_marginStart="-32dp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Our AI analyzes the image instantly"
                                android:textSize="14sp"
                                android:textColor="#1F2937" />

                        </LinearLayout>

                        <!-- Step 3 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">

                            <View
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:background="@drawable/step_circle"
                                android:layout_marginEnd="16dp" />

                            <TextView
                                android:layout_width="8dp"
                                android:layout_height="wrap_content"
                                android:text="3"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold"
                                android:textSize="12sp"
                                android:gravity="center"
                                android:layout_marginEnd="24dp"
                                android:layout_marginStart="-32dp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Get detailed health insights and recommendations"
                                android:textSize="14sp"
                                android:textColor="#1F2937" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Tips (initially hidden) â€" placed RIGHT BELOW instructionsCard -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/tipsFloatingCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="12dp"
                android:backgroundTint="#DDECF8"
                android:visibility="gone"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_lightbulb"
                            app:tint="#FFD700"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Pro Tips for Better Results"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#2E5BBA" />

                        <ImageButton
                            android:id="@+id/closeTipsButton"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_close"
                            android:background="@drawable/circular_button_background" />

                    </LinearLayout>

                    <!-- Tips List -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Tip 1 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="top"
                            android:layout_marginBottom="12dp">

                            <View
                                android:layout_width="6dp"
                                android:layout_height="6dp"
                                android:background="@drawable/tip_bullet"
                                android:layout_marginTop="6dp"
                                android:layout_marginEnd="12dp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Ensure good lighting - natural light works best"
                                android:textSize="14sp"
                                android:textColor="#0F0F10"
                                android:lineSpacingMultiplier="1.3" />

                        </LinearLayout>

                        <!-- Tip 2 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="top"
                            android:layout_marginBottom="12dp">

                            <View
                                android:layout_width="6dp"
                                android:layout_height="6dp"
                                android:background="@drawable/tip_bullet"
                                android:layout_marginTop="6dp"
                                android:layout_marginEnd="12dp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Take clear, focused photos without blur"
                                android:textSize="14sp"
                                android:textColor="#111112"
                                android:lineSpacingMultiplier="1.3" />

                        </LinearLayout>

                        <!-- Tip 3 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="top"
                            android:layout_marginBottom="12dp">

                            <View
                                android:layout_width="6dp"
                                android:layout_height="6dp"
                                android:background="@drawable/tip_bullet"
                                android:layout_marginTop="6dp"
                                android:layout_marginEnd="12dp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Show areas of concern clearly and close-up"
                                android:textSize="14sp"
                                android:textColor="#0A0A0B"
                                android:lineSpacingMultiplier="1.3" />

                        </LinearLayout>

                        <!-- Tip 4 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="top">

                            <View
                                android:layout_width="6dp"
                                android:layout_height="6dp"
                                android:background="@drawable/tip_bullet"
                                android:layout_marginTop="6dp"
                                android:layout_marginEnd="12dp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Include your pet's face if possible for better analysis"
                                android:textSize="14sp"
                                android:textColor="#0E0E0E"
                                android:lineSpacingMultiplier="1.3" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Image Upload Section with Enhanced UI -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                android:backgroundTint="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="20dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_photo"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Pet Photo"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#2E5BBA" />

                        <View
                            android:id="@+id/uploadStatus"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="@drawable/status_circle"
                            android:backgroundTint="#E5E7EB" />

                    </LinearLayout>

                    <!-- Enhanced Image Container -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="280dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="2dp"
                        android:backgroundTint="#F8FAFC"
                        android:layout_marginBottom="20dp">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:id="@+id/imageView"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:adjustViewBounds="true" />

                            <!-- Placeholder overlay -->
                            <LinearLayout
                                android:id="@+id/placeholderLayout"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:background="@drawable/dashed_border">

                                <ImageView
                                    android:layout_width="64dp"
                                    android:layout_height="64dp"
                                    android:src="@drawable/ic_camera_alt"
                                    android:layout_marginBottom="12dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Tap to upload pet photo"
                                    android:textSize="16sp"
                                    android:textColor="#6B7280"
                                    android:textStyle="bold"
                                    android:layout_marginBottom="8dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="JPG, PNG • Max 10MB"
                                    android:textSize="12sp"
                                    android:textColor="#9CA3AF" />

                            </LinearLayout>

                        </FrameLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Enhanced Upload Button -->
                    <Button
                        android:id="@+id/uploadBtn"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Choose Photo from Gallery"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        android:background="@drawable/primary_button_background"
                        android:textColor="@android:color/white"
                        android:elevation="3dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Analysis Section with Enhanced Design -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                android:backgroundTint="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="20dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_analytics"
                            app:tint="#2E5BBA"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="AI Analysis"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#2E5BBA" />

                        <ImageView
                            android:id="@+id/aiIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_smart_toy" />

                    </LinearLayout>

                    <!-- Enhanced Analyze Button -->
                    <Button
                        android:id="@+id/analyseBtn"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="🧠 Analyze Pet Health"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        android:background="@drawable/secondary_button_background"
                        android:textColor="@android:color/white"
                        android:elevation="3dp"
                        android:enabled="false" />

                    <!-- Enhanced Loading Section -->
                    <LinearLayout
                        android:id="@+id/loadingContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginTop="24dp"
                        android:visibility="gone"
                        android:background="@drawable/loading_background"
                        android:padding="20dp">

                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:id="@+id/progressBar"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_marginBottom="16dp"
                            app:indicatorColor="#2E5BBA"
                            app:trackColor="#E5E7EB" />

                        <TextView
                            android:id="@+id/loadingText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🧠 AI is analyzing your pet's image...\nThis may take a moment"
                            android:textSize="14sp"
                            android:textColor="#374151"
                            android:textAlignment="center"
                            android:lineSpacingMultiplier="1.4"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Powered by Advanced Computer Vision"
                            android:textSize="12sp"
                            android:textColor="#6B7280"
                            android:textAlignment="center"
                            android:layout_marginTop="8dp"
                            android:textStyle="italic" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

    <!-- Fixed Bottom Navigation Bar -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentBottom="true"
        android:background="#025293"
        app:labelVisibilityMode="labeled"
        app:itemIconTint="@color/white"
        app:itemTextColor="@color/white"
        app:menu="@menu/bottom_nav"
        android:elevation="8dp" />

</RelativeLayout>