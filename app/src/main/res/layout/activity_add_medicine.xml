<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background"
    android:padding="24dp"
    android:fillViewport="true"
    tools:context=".petschedule.ui.AddMedicineActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_background"
        android:padding="32dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        android:elevation="8dp"
        android:translationZ="8dp">

        <!-- App Header Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💊"
                android:textSize="32sp"
                android:layout_marginBottom="8dp"
                android:scaleX="1.2"
                android:scaleY="1.2"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Add Medicine"
                android:textStyle="bold"
                android:textSize="36sp"
                android:textColor="@color/primary_blue"
                android:gravity="center"
                android:letterSpacing="0.05"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Track your pet's medication schedule"
                android:textSize="18sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginTop="8dp"
                android:alpha="0.8"/>
        </LinearLayout>

        <!-- Medicine Name Field -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/medicine_name_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="@style/CustomTextInputLayout"
            app:boxStrokeColor="@color/primary_blue"
            app:hintTextColor="@color/primary_blue"
            app:startIconTint="@color/primary_blue"
            app:endIconMode="clear_text"
            app:endIconTint="@color/primary_blue"
            app:errorEnabled="true"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editTextMedicineName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Medicine Name"
                android:inputType="text|textCapWords"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:padding="16dp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Dosage Field -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/dosage_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="@style/CustomTextInputLayout"
            app:boxStrokeColor="@color/primary_blue"
            app:hintTextColor="@color/primary_blue"
            app:startIconTint="@color/primary_blue"
            app:endIconMode="clear_text"
            app:endIconTint="@color/primary_blue"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editTextDosage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Dosage (e.g., 1 tablet, 5ml)"
                android:inputType="text"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:padding="16dp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Enhanced Frequency Section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/primary_blue_light"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="@color/quantum_white_100">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_schedule"
                        android:layout_marginEnd="12dp"
                        app:tint="@color/primary_blue" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Frequency Feed"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_blue"/>
                </LinearLayout>

                <RadioGroup
                    android:id="@+id/radioGroupFrequency"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/radioOnceDaily"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Once Daily"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:padding="8dp"
                        android:layout_marginBottom="4dp"
                        android:checked="true"/>

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/radioTwiceDaily"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Twice Daily"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:padding="8dp"
                        android:layout_marginBottom="4dp"/>

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/radioThreeTimesDaily"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Three Times Daily"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:padding="8dp"
                        android:layout_marginBottom="4dp"/>

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/radioWeekly"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Weekly"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:padding="8dp"/>
                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Start & End Date Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/start_date_layout"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                style="@style/CustomTextInputLayout"
                app:boxStrokeColor="@color/primary_blue"
                app:hintTextColor="@color/primary_blue"
                app:startIconTint="@color/primary_blue"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                android:layout_marginEnd="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editTextStartDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Start Date"
                    android:inputType="none"
                    android:focusable="false"
                    android:clickable="true"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:padding="16dp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/end_date_layout"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                style="@style/CustomTextInputLayout"
                app:boxStrokeColor="@color/primary_blue"
                app:hintTextColor="@color/primary_blue"
                app:startIconTint="@color/primary_blue"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                android:layout_marginStart="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editTextEndDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="End Date"
                    android:inputType="none"
                    android:focusable="false"
                    android:clickable="true"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:padding="16dp"/>
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Enhanced Time Selector Section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/primary_blue_light"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp"
                    android:gravity="center_vertical">


                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Feed Times"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_blue"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:hyphenationFrequency="none"
                        android:breakStrategy="balanced" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonAddTime"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Add Time"
                        android:textSize="12sp"
                        android:textColor="@color/primary_blue"
                        android:minWidth="0dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        app:strokeColor="@color/primary_blue"
                        app:strokeWidth="1dp"
                        app:cornerRadius="20dp"
                        app:rippleColor="@color/primary_blue_light"
                        app:iconTint="@color/primary_blue"
                        app:iconSize="16dp"/>
                </LinearLayout>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/timeChipGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:chipSpacing="8dp"
                    app:lineSpacing="8dp"
                    app:chipSpacingHorizontal="8dp"
                    app:chipSpacingVertical="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Notes Field -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/notes_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            style="@style/CustomTextInputLayout"
            app:boxStrokeColor="@color/primary_blue"
            app:hintTextColor="@color/primary_blue"
            app:startIconTint="@color/primary_blue"
            app:endIconMode="clear_text"
            app:endIconTint="@color/primary_blue"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editTextNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Notes (Optional)"
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="3"
                android:maxLines="5"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:padding="16dp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Enhanced Save Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSaveMedicine"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Save Medicine"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@android:color/white"
            android:background="@drawable/gradient_button"
            app:cornerRadius="28dp"
            android:layout_marginBottom="16dp"
            android:elevation="4dp"
            app:rippleColor="@color/white_transparent"
            android:stateListAnimator="@animator/button_elevation"
            app:iconTint="@android:color/white"
            app:iconGravity="textStart"/>

        <!-- Progress Bar (Hidden by default) -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            app:indicatorColor="@color/primary_blue"
            app:trackColor="@color/primary_blue_light"
            app:trackCornerRadius="4dp" />

    </LinearLayout>
</ScrollView>