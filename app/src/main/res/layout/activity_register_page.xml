<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background"
    android:padding="24dp"
    android:fillViewport="true"
    tools:context=".RegisterPage">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_background"
        android:padding="32dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        android:elevation="8dp"
        android:translationZ="8dp">

        <!-- App Logo and Name -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🐾"
                android:textSize="32sp"
                android:layout_marginBottom="8dp"
                android:scaleX="1.2"
                android:scaleY="1.2"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PawLife"
                android:textStyle="bold"
                android:textSize="36sp"
                android:textColor="@color/primary_blue"
                android:gravity="center"
                android:letterSpacing="0.05"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Create New Account"
                android:textSize="18sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginTop="8dp"
                android:alpha="0.8"/>
        </LinearLayout>

        <!-- Enhanced Avatar Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="32dp">

            <FrameLayout
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center">

                <ImageView
                    android:id="@+id/iv_avatar"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center"
                    android:background="@drawable/avatar_background_gradient"
                    android:scaleType="centerCrop"
                    android:src="@drawable/icuser"
                    android:clipToOutline="true"
                    android:elevation="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackgroundBorderless"/>


            </FrameLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_select_avatar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Choose Avatar"
                android:textSize="14sp"
                android:textColor="@color/primary_blue"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/primary_blue"
                app:strokeWidth="2dp"
                app:cornerRadius="20dp"
                android:layout_marginTop="16dp"
                android:paddingHorizontal="24dp"
                app:rippleColor="@color/primary_blue_light"
                android:elevation="2dp"/>
        </LinearLayout>

        <!-- Enhanced Form Fields -->
        <!-- First & Last Name Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                style="@style/CustomTextInputLayout"
                app:boxStrokeColor="@color/primary_blue"
                app:hintTextColor="@color/primary_blue"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                android:layout_marginEnd="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_firstname"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="First Name"
                    android:inputType="textPersonName|textCapWords"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:padding="16dp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                style="@style/CustomTextInputLayout"
                app:boxStrokeColor="@color/primary_blue"
                app:hintTextColor="@color/primary_blue"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                android:layout_marginStart="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_lastname"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Last Name"
                    android:inputType="textPersonName|textCapWords"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:padding="16dp"/>
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Age Field -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="@style/CustomTextInputLayout"
            app:boxStrokeColor="@color/primary_blue"
            app:hintTextColor="@color/primary_blue"
            app:startIconDrawable="@drawable/ic_cake"
            app:startIconTint="@color/primary_blue"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_age"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Age"
                android:inputType="number"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:padding="16dp"
                android:maxLength="2"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Email Field with Helper Text -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/email_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="@style/CustomTextInputLayout"
            app:boxStrokeColor="@color/primary_blue"
            app:hintTextColor="@color/primary_blue"
            app:startIconDrawable="@drawable/ic_email"
            app:startIconTint="@color/primary_blue"
            app:errorEnabled="true"
            app:helperTextEnabled="true"
            app:helperText="Format: yourname@paw.com"
            app:helperTextTextColor="@color/text_secondary"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Email Address @paw.com"
                android:inputType="textEmailAddress"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:padding="16dp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Phone Number Field -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="@style/CustomTextInputLayout"
            app:boxStrokeColor="@color/primary_blue"
            app:hintTextColor="@color/primary_blue"
            app:startIconDrawable="@drawable/ic_phone"
            app:startIconTint="@color/primary_blue"
            app:errorEnabled="true"
            app:helperTextEnabled="true"
            app:helperText="Format: 01123456789"
            app:counterEnabled="true"
            app:counterMaxLength="11"
            app:helperTextTextColor="@color/text_secondary"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_phone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Phone Number"
                android:inputType="phone"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:padding="16dp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Password Field -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/password_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="@style/CustomTextInputLayout"
            app:boxStrokeColor="@color/primary_blue"
            app:hintTextColor="@color/primary_blue"
            app:startIconDrawable="@drawable/ic_lock"
            app:startIconTint="@color/primary_blue"
            app:endIconMode="password_toggle"
            app:endIconTint="@color/primary_blue"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_password"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Password"
                android:inputType="textPassword"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:padding="16dp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Re-enter Password Field -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/reenter_password_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            style="@style/CustomTextInputLayout"
            app:boxStrokeColor="@color/primary_blue"
            app:hintTextColor="@color/primary_blue"
            app:startIconDrawable="@drawable/ic_lock"
            app:startIconTint="@color/primary_blue"
            app:endIconMode="password_toggle"
            app:endIconTint="@color/primary_blue"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_reenter_password"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Confirm Password"
                android:inputType="textPassword"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:padding="16dp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Enhanced Sign Up Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_signup"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Create Account"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@android:color/white"
            android:background="@drawable/gradient_button"
            app:cornerRadius="28dp"
            android:layout_marginBottom="24dp"
            android:elevation="4dp"
            app:rippleColor="@color/white_transparent"
            android:stateListAnimator="@animator/button_elevation"/>

        <!-- Login Link -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Already have an account? "
                android:textSize="15sp"
                android:textColor="@color/text_secondary"/>

            <TextView
                android:id="@+id/tvLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign In"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/primary_blue"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:padding="8dp"/>
        </LinearLayout>

        <!-- Progress Bar (Hidden by default) -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            app:indicatorColor="@color/primary_blue"
            app:trackColor="@color/primary_blue_light"
            app:trackCornerRadius="4dp" />

    </LinearLayout>
</ScrollView>