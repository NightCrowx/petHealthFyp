<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="56dp"
    android:layout_height="56dp"
    android:orientation="vertical"
    android:gravity="center"
    android:layout_marginEnd="8dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="2dp"
        app:strokeWidth="2dp"
        app:strokeColor="#E0E0E0">

        <ImageView
            android:id="@+id/petProfileImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_pet_default"
            android:contentDescription="Pet Profile" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Optional: Pet name indicator (small dot or initial) -->
    <TextView
        android:id="@+id/petInitial"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:layout_marginTop="2dp"
        android:background="@drawable/circle_background"
        android:backgroundTint="#025293"
        android:gravity="center"
        android:text="A"
        android:textColor="@android:color/white"
        android:textSize="8sp"
        android:textStyle="bold"
        android:visibility="gone" />

</LinearLayout>