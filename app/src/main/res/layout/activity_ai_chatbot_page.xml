<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/pawlife_chat_background"
    tools:context=".AiChatbotPage">

    <!-- Stylized Header with PawLife Theme -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/chatHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/header_gradient"
        android:padding="16dp"
        android:elevation="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- NEW: Close button positioned in top-right -->
        <androidx.cardview.widget.CardView
            android:id="@+id/closeChatCard"
            android:layout_width="36dp"
            android:layout_height="36dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/bluelight"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageButton
                android:id="@+id/closeChatBtn"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:contentDescription="Close Chat"
                android:tint="@android:color/white"
                android:padding="8dp" />
        </androidx.cardview.widget.CardView>

        <!-- Animated paw prints decoration -->
        <ImageView
            android:id="@+id/pawDecoration1"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/paw_print_small"
            android:alpha="0.3"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:id="@+id/pawDecoration2"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/paw_print_small"
            android:alpha="0.2"
            android:layout_marginEnd="40dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Bot Profile with circular frame -->
        <androidx.cardview.widget.CardView
            android:id="@+id/botProfileCard"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/botProfile"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/icvet"
                android:scaleType="centerCrop" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:id="@+id/botTextInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            app:layout_constraintStart_toEndOf="@id/botProfileCard"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/pawDecoration2">

            <TextView
                android:id="@+id/botName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Doctor Paw"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/statusIndicator"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/online_status_circle"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/botStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ready to help your pet!"
                    android:textColor="@color/pawlife_light_blue"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-light" />
            </LinearLayout>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Enhanced Scrollable chat area with paw-themed styling -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:paddingTop="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/chatHeader"
        app:layout_constraintBottom_toTopOf="@id/quickEducationSection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/messageContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp" />
    </ScrollView>

    <!-- NEW: Quick Education Section -->
    <LinearLayout
        android:id="@+id/quickEducationSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/pawlife_light_gray"
        android:elevation="2dp"
        app:layout_constraintBottom_toTopOf="@id/inputLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Education Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎓 Quick Pet Education"
            android:textColor="@color/pawlife_primary"
            android:textStyle="bold"
            android:textSize="14sp"
            android:padding="12dp"
            android:paddingBottom="8dp"
            android:fontFamily="sans-serif-medium" />

        <!-- Horizontal scrollable education buttons -->
        <HorizontalScrollView
            android:id="@+id/quickEducationContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingBottom="12dp">

            <!-- The button container will be added programmatically in setupQuickEducationButtons() -->

        </HorizontalScrollView>

    </LinearLayout>

    <!-- Redesigned Input layout with PawLife styling -->
    <LinearLayout
        android:id="@+id/inputLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/pawlife_input_background"
        android:padding="12dp"
        android:elevation="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Enhanced image preview container -->
        <androidx.cardview.widget.CardView
            android:id="@+id/imagePreviewContainer"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/attachedImagePreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop" />

                <androidx.cardview.widget.CardView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="end|top"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="14dp"
                    app:cardBackgroundColor="@color/pawlife_red"
                    app:cardElevation="2dp">

                    <ImageButton
                        android:id="@+id/removeImageBtn"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        android:contentDescription="Remove image"
                        android:tint="@android:color/white"
                        android:padding="4dp" />
                </androidx.cardview.widget.CardView>
            </FrameLayout>
        </androidx.cardview.widget.CardView>

        <!-- Input row with enhanced styling -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/pawlife_input_row_bg"
            android:padding="4dp">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardCornerRadius="25dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white">

                <EditText
                    android:id="@+id/userInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Ask Doctor Paw question..."
                    android:textColorHint="@color/pawlife_gray"
                    android:textColor="@android:color/black"
                    android:padding="16dp"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:background="@android:color/transparent"
                    android:inputType="textMultiLine"
                    android:maxLines="4"
                    android:fontFamily="sans-serif"
                    android:textSize="16sp" />
            </androidx.cardview.widget.CardView>

            <!-- Camera button with paw-themed styling -->
            <androidx.cardview.widget.CardView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/pawlife_light_blue">

                <ImageButton
                    android:id="@+id/imageSelectBtn"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@android:drawable/ic_menu_camera"
                    android:background="@android:color/transparent"
                    android:tint="@android:color/white"
                    android:contentDescription="Add image"
                    android:padding="12dp" />
            </androidx.cardview.widget.CardView>

            <!-- Send button with gradient and paw animation -->
            <androidx.cardview.widget.CardView
                android:layout_width="56dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/pawlife_primary">

                <Button
                    android:id="@+id/sendBtn"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text=">"
                    android:textSize="18sp"
                    android:background="@android:color/transparent"
                    android:textColor="@android:color/white"
                    android:fontFamily="sans-serif-medium" />
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </LinearLayout>

    <!-- Enhanced loading indicator with paw animation -->
    <androidx.cardview.widget.CardView
        android:id="@+id/loadingCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/pawlife_white_overlay"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center">

            <ProgressBar
                android:id="@+id/loadingIndicator"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:indeterminate="true"
                android:indeterminateTint="@color/pawlife_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Doctor Paw is thinking..."
                android:textColor="@color/pawlife_primary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="12dp" />

            <!-- Animated paw prints -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/paw_print_tiny"
                    android:layout_marginEnd="4dp"
                    android:alpha="0.6" />

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/paw_print_tiny"
                    android:layout_marginEnd="4dp"
                    android:alpha="0.4" />

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/paw_print_tiny"
                    android:alpha="0.2" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>