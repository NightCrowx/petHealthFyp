<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@android:color/white"
    app:strokeWidth="1dp"
    app:strokeColor="#E8F4FD">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header: gradient + circular icon + title + time chip -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_appointment_tag"
            android:padding="16dp">

            <!-- Appointment Icon (id declared here) -->
            <ImageView
                android:id="@+id/imageViewAppointmentIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="12dp"
                android:background="@drawable/circular_button_background"
                android:padding="8dp"
                android:src="@drawable/ic_calendar" />

            <!-- IMPORTANT: reference with @id/, not @+id/ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/imageViewAppointmentIcon"
                android:layout_centerVertical="true"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textViewAppointmentTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:text="Appointment Title"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- Time Chip (kept id) -->
                <com.google.android.material.chip.Chip
                    android:id="@+id/textViewAppointmentTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="10:00 AM"
                    android:textSize="11sp"
                    android:textColor="#2C3E50"
                    app:chipIcon="@drawable/ic_time"
                    app:chipIconTint="#2C3E50"
                    app:chipIconVisible="true"
                    app:chipBackgroundColor="#80FFFFFF"
                    app:chipStrokeColor="@android:color/white"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="12dp"
                    app:chipMinHeight="24dp" />
            </LinearLayout>
        </RelativeLayout>

        <!-- Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@android:color/white">

            <!-- Location row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp"
                android:background="@drawable/date_background"
                android:padding="12dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="8dp"
                    android:src="@drawable/ic_location_small"
                    app:tint="#4A90E2" />

                <TextView
                    android:id="@+id/textViewLocation"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Location: Clinic Name"
                    android:textColor="#2C3E50"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Big Date Box section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/time_background"
                android:padding="12dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Appointment Date"
                        android:textColor="#2C3E50"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/dateBoxContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <LinearLayout
                        android:id="@+id/dateBox"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/date_box_background"
                        android:padding="16dp"
                        android:gravity="center"
                        android:minWidth="120dp">

                        <TextView
                            android:id="@+id/textViewDay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="25"
                            android:textColor="#2C3E50"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:gravity="center" />

                        <TextView
                            android:id="@+id/textViewMonth"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DEC"
                            android:textColor="#E74C3C"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp"
                            android:gravity="center" />

                        <TextView
                            android:id="@+id/textViewYear"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2024"
                            android:textColor="#7F8C8D"
                            android:textSize="10sp"
                            android:layout_marginTop="2dp"
                            android:gravity="center" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Keep for adapter compatibility (unchanged id) -->
            <TextView
                android:id="@+id/textViewAppointmentDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Date"
                android:textSize="0sp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Bottom status bar -->
        <View
            android:id="@+id/viewStatusBar"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:background="#4A90E2" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
