<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@android:color/white"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:strokeWidth="1dp"
    app:strokeColor="#E8F4FD">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header Section with Vaccine Name and Status Badge -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/vaccination_header_gradient"
            android:padding="16dp">

            <!-- Vaccination Icon -->
            <ImageView
                android:id="@+id/imageViewVaccinationIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_vaccination"
                android:background="@drawable/circular_button_background"
                android:padding="8dp"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/imageViewVaccinationIcon"
                android:layout_centerVertical="true"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textViewVaccineName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Vaccine Name"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:maxLines="2"
                    android:ellipsize="end" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/textViewStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pending"
                    android:textSize="11sp"
                    android:textColor="@color/black"
                    app:chipBackgroundColor="#80FFFFFF"
                    app:chipStrokeColor="@android:color/white"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="12dp"
                    app:chipMinHeight="24dp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

        </RelativeLayout>

        <!-- Content Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@android:color/white">

            <!-- Due Date Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp"
                android:background="@drawable/date_background"
                android:padding="12dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_calendar_small"
                    android:layout_marginEnd="8dp"
                    app:tint="#4A90E2" />

                <TextView
                    android:id="@+id/textViewDueDate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Due Date: 25/12/2024"
                    android:textSize="14sp"
                    android:textColor="#2C3E50"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Date Box Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/time_background"
                android:padding="12dp"
                android:layout_marginBottom="8dp">

                <!-- Date Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">


                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Scheduled Date"
                        android:textSize="20sp"
                        android:textColor="#2C3E50"
                        android:textStyle="bold" />


                </LinearLayout>

                <!-- Date Box Container -->
                <LinearLayout
                    android:id="@+id/dateBoxContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <!-- Date Box -->
                    <LinearLayout
                        android:id="@+id/dateBox"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/date_box_background"
                        android:padding="16dp"
                        android:gravity="center"
                        android:minWidth="120dp">

                        <TextView
                            android:id="@+id/textViewDay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="25"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="#2C3E50"
                            android:gravity="center" />

                        <TextView
                            android:id="@+id/textViewMonth"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DEC"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#E74C3C"
                            android:layout_marginTop="2dp"
                            android:gravity="center" />

                        <TextView
                            android:id="@+id/textViewYear"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2024"
                            android:textSize="10sp"
                            android:textColor="#7F8C8D"
                            android:layout_marginTop="2dp"
                            android:gravity="center" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Status Bar -->
        <View
            android:id="@+id/viewStatusBar"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:background="#E74C3C" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>